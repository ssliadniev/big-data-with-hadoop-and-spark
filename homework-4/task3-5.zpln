    {
      "text": "%jdbc(hive)\n\n\nSET hive.server2.in.place.progress=false;\n\nWITH RankedTaggedMovies AS (\n    SELECT \n        t.Tag,\n        m.Title,\n        AVG(r.Rating) AS avg_rating,\n        DENSE_RANK() OVER (PARTITION BY t.Tag ORDER BY AVG(r.Rating) DESC) as rank\n    FROM tags_text t\n    JOIN ratings_text r ON t.MovieID = r.MovieID\n    JOIN movies_text m ON t.MovieID = m.MovieID\n    WHERE t.Tag IN ('based on a book', 'based on a play')\n    GROUP BY t.Tag, t.MovieID, m.Title\n)\n\nSELECT \n    Tag,\n    Title,\n    avg_rating,\n    rank\nFROM RankedTaggedMovies\nWHERE rank <= 5\nORDER BY Tag, rank ASC;",
      "user": "anonymous",
      "dateUpdated": "2026-03-14T17:38:48+0000",
      "progress": 0,
      "config": {
