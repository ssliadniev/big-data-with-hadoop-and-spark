    {
      "title": "[TASK-3] Creating partitioned table mimicking ratings_text",
      "text": "%jdbc(hive)\n\n\nCREATE TABLE IF NOT EXISTS ratings_task3 (\n    UserID INT,\n    MovieID INT,\n    Rating DOUBLE,\n    Time_stamp BIGINT\n)\nPARTITIONED BY (year INT)\nSTORED AS TEXTFILE;",
