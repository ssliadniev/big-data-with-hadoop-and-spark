    {
      "title": "[TASK-3] Loading data into created table",
      "text": "%jdbc(hive)\n\n\nSET hive.exec.dynamic.partition=true;\nSET hive.exec.dynamic.partition.mode=nonstrict;\nSET hive.server2.in.place.progress=false;\n\n\nINSERT OVERWRITE TABLE ratings_task3 PARTITION(year)\nSELECT \n    UserID, \n    MovieID, \n    Rating, \n    Time_stamp,\n    year(from_unixtime(Time_stamp)) AS year\nFROM ratings_text;",
      "user": "anonymous",
      "dateUpdated": "2026-03-14T16:59:10+0000",
