    {
      "title": "[TASK-4] Count movies by genre",
      "text": "%jdbc(hive)\n\n\nSET hive.server2.in.place.progress=false;\n\nSELECT \n    genre, \n    COUNT(MovieID) AS cnt\nFROM movies_text\nLATERAL VIEW explode(split(Genres, '\\\\|')) exploded_table AS genre\nGROUP BY genre\nHAVING cnt > 200\nORDER BY cnt DESC;",
      "user": "anonymous",
      "dateUpdated": "2026-03-14T17:08:07+0000",
