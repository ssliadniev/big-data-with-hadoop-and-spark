      "title": "",
      "text": "%pyspark\n\nimport requests\nimport base64\nimport google.auth\n\nfrom google.auth.transport.requests import Request\nfrom pyspark.sql import functions as F\n\n\nPROJECT_ID = \"big-data-488723\"\nTOPIC_ID = \"fraud_transactions_topic\"\n\nclass PubSubWriter:\n    def open(self, partition_id, epoch_id):\n        self.credentials, _ = google.auth.default()\n        self.credentials.refresh(Request())\n\n        self.url = f\"https://pubsub.googleapis.com/v1/projects/{PROJECT_ID}/topics/{TOPIC_ID}:publish\"\n        self.headers = {\n            \"Authorization\": f\"Bearer {self.credentials.token}\",\n            \"Content-Type\": \"application/json\"\n        }\n        self.messages = []\n        return True\n\n    def process(self, row):\n        if row.value is None:\n            return\n\n        message_bytes = row.value.encode(\"utf-8\")\n        base64_string = base64.b64encode(message_bytes).decode(\"utf-8\")\n        self.messages.append({\"data\": base64_string})\n\n        if len(self.messages) >= 50:\n            self._flush()\n\n    def close(self, error):\n        try:\n            if self.messages:\n                self._flush()\n        finally:\n            if error:\n                print(f\"Writer closed with error: {error}\")\n\n    def _flush(self):\n        response = requests.post(\n            self.url,\n            headers=self.headers,\n            json={\"messages\": self.messages},\n            timeout=30\n        )\n        response.raise_for_status()\n        self.messages = []",
      "user": "anonymous",
      "dateUpdated": "2026-03-17T16:24:56+0000",
      "progress": 0,
