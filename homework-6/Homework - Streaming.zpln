    {
      "title": "Streaming example - run this in pyspark shell",
      "text": "%pyspark\n\nimport json\nimport time\nimport base64\nimport requests\nimport google.auth\nfrom google.auth.transport.requests import Request\n\nfrom pyspark.sql import functions as F\nfrom pyspark.sql.types import (\n    StructType, StructField, StringType, DoubleType, IntegerType, TimestampType\n)\n\nPROJECT_ID = \"big-data-488723\"\nSUBSCRIPTION_ID = \"fraud_transactions_topic-sub\"\nSUBSCRIPTION_PATH = f\"projects/{PROJECT_ID}/subscriptions/{SUBSCRIPTION_ID}\"\n\nHDFS_PATH = \"hdfs:///user/zeppelin/fraud_txn_output_rest\"\nPOLL_BATCH_SIZE = 200\nSLEEP_IF_EMPTY_SEC = 5\n\ntxn_schema = StructType([\n    StructField(\"step\", IntegerType(), True),\n    StructField(\"type\", StringType(), True),\n    StructField(\"amount\", DoubleType(), True),\n    StructField(\"nameOrig\", StringType(), True),\n    StructField(\"oldbalanceOrg\", DoubleType(), True),\n    StructField(\"newbalanceOrig\", DoubleType(), True),\n    StructField(\"nameDest\", StringType(), True),\n    StructField(\"oldbalanceDest\", DoubleType(), True),\n    StructField(\"newbalanceDest\", DoubleType(), True),\n    StructField(\"isFraud\", IntegerType(), True),\n    StructField(\"isFlaggedFraud\", IntegerType(), True)\n])\n\noutput_schema = StructType(txn_schema.fields + [\n    StructField(\"pubsub_message_id\", StringType(), True),\n    StructField(\"pubsub_publish_time\", StringType(), True),\n    StructField(\"ingest_ts\", TimestampType(), True)\n])\n\ndef get_auth_headers():\n    creds, _ = google.auth.default()\n    creds.refresh(Request())\n    return {\n        \"Authorization\": f\"Bearer {creds.token}\",\n        \"Content-Type\": \"application/json\"\n    }\n\ndef pull_messages(max_messages=POLL_BATCH_SIZE):\n    url = f\"https://pubsub.googleapis.com/v1/{SUBSCRIPTION_PATH}:pull\"\n    headers = get_auth_headers()\n    payload = {\n        \"maxMessages\": max_messages\n    }\n\n    resp = requests.post(url, headers=headers, json=payload, timeout=30)\n    resp.raise_for_status()\n    data = resp.json()\n\n    return data.get(\"receivedMessages\", [])\n\ndef acknowledge_messages(ack_ids):\n    if not ack_ids:\n        return\n\n    url = f\"https://pubsub.googleapis.com/v1/{SUBSCRIPTION_PATH}:acknowledge\"\n    headers = get_auth_headers()\n    payload = {\n        \"ackIds\": ack_ids\n    }\n\n    resp = requests.post(url, headers=headers, json=payload, timeout=30)\n    resp.raise_for_status()\n\ndef received_to_rows(received_messages):\n    rows = []\n\n    for rm in received_messages:\n        msg = rm.get(\"message\", {})\n        raw_data = msg.get(\"data\")\n        if not raw_data:\n            continue\n\n        decoded_json = base64.b64decode(raw_data).decode(\"utf-8\")\n        payload = json.loads(decoded_json)\n\n        payload[\"pubsub_message_id\"] = msg.get(\"messageId\")\n        payload[\"pubsub_publish_time\"] = msg.get(\"publishTime\")\n        rows.append(payload)\n\n    return rows\n\ndef write_rows_to_hdfs(rows):\n    if not rows:\n        return 0\n\n    df = spark.createDataFrame(rows, schema=output_schema).withColumn(\n        \"ingest_ts\", F.current_timestamp()\n    ).withColumn(\n        colName=\"ingest_date\", col=F.to_date(\"ingest_ts\")\n    )\n\n    (\n        df.write\n          .mode(\"append\")\n          .partitionBy(\"ingest_date\")\n          .parquet(HDFS_PATH)\n    )\n\n    return len(rows)\n\nprint(\"Starting Pub/Sub REST -> Spark -> HDFS loop.\")\n\nwhile True:\n    received = pull_messages()\n\n    if not received:\n        print(\"No messages, sleeping...\")\n        time.sleep(SLEEP_IF_EMPTY_SEC)\n        continue\n\n    ack_ids = [x[\"ackId\"] for x in received if \"ackId\" in x]\n    rows = received_to_rows(received)\n\n    try:\n        written = write_rows_to_hdfs(rows)\n        acknowledge_messages(ack_ids)\n        print(f\"Written {written} rows to HDFS and acked {len(ack_ids)} messages\")\n    except Exception as e:\n        print(f\"Batch failed, not acknowledging messages: {e}\")\n        time.sleep(3)",
      "user": "anonymous",
