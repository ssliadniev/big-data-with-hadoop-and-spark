    {
      "text": "%pyspark\n\n\nschema_obj = spark.read.csv(\n    \"gs://oklev-uku-datasets/fraud-detection-splitted\",\n    header=True,\n    inferSchema=True\n).schema\n\ndf = (\n    spark.readStream\n        .schema(schema_obj)\n        .option(\"header\", True)\n        .option(\"maxFilesPerTrigger\", 1)\n        .csv(\"gs://oklev-uku-datasets/fraud-detection-splitted\")\n)\n\njson_df = df.select(\n    F.to_json(F.struct(*[F.col(c) for c in df.columns])).alias(\"value\")\n)\n\nquery = (\n    json_df.writeStream\n        .foreach(PubSubWriter())\n        .option(\"checkpointLocation\", \"gs://big-data-2026-staging/checkpoints/streaming_task\")\n        .start()\n)\n",
