    {
      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\nmovies_with_year_df = movies_df.withColumn(\n    colName=\"year\", \n    col=F.regexp_extract(F.col(\"title\"), r\"\\((\\d{4})\\)\", 1).cast(\"int\")\n)\n\nmin_max_years_df = movies_with_year_df.filter(F.col(\"year\").isNotNull()).select(\n    F.min(\"year\").alias(\"earliest_year\"),\n    F.max(\"year\").alias(\"latest_year\")\n)\n\nmin_max_years_df.show()\n\n",
      "user": "anonymous",
      "dateUpdated": "2026-03-15T21:41:37+0000",
      "progress": 0,
      "config": {
