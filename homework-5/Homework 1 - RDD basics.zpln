      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\nmovies_with_title_length_df = movies_df.withColumn(\n    colName=\"title_length\", \n    col=F.length(F.col(\"title\"))\n)\n\nlongest_movies_df = movies_with_title_length_df.orderBy(F.col(\"title_length\").desc())\nlongest_movies_df.select(\"title\", \"title_length\").show(1, truncate=False)",
