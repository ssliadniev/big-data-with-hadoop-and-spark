    {
      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\nexploded_movies_df = movies_df.withColumn(\n    colName=\"single_genre\", \n    col=F.explode(F.split(F.col(\"genres\"), r\"\\|\"))\n)\n\ngenre_counts_df = exploded_movies_df.groupBy(\"single_genre\").count()\nsorted_genre_counts_df = genre_counts_df.orderBy(F.col(\"count\").desc())\n\nsorted_genre_counts_df.show(truncate=False)",
