      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\nexploded_genres_df = movies_df.select(\n    F.explode(F.split(F.col(\"genres\"), r\"\\|\")).alias(\"genre\")\n)\n\nunique_genres_df = exploded_genres_df.distinct()\nunique_genres_df.show(truncate=False)",
