    {
      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\nmovies_with_genre_count_df = movies_df.withColumn(\n    colName=\"genre_count\", \n    col=F.size(F.split(F.col(\"genres\"), r\"\\|\"))\n)\n\ngenre_stats_df = movies_with_genre_count_df.select(\n    F.min(\"genre_count\").alias(\"min_genres\"),\n    F.round(F.avg(\"genre_count\"), 2).alias(\"avg_genres\"),\n    F.max(\"genre_count\").alias(\"max_genres\")\n)\n\ngenre_stats_df.show()\n",
      "user": "anonymous",
