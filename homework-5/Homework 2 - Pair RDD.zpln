    {
      "text": "%pyspark\n\n\nmovies_df = spark.read.csv(\"gs://oklev-uku-datasets/movie-ratings/movies.csv\", header=True, inferSchema=True)\nratings_df = spark.read.csv(\"gs://oklev-uku-datasets/movie-ratings/ratings.csv\", header=True, inferSchema=True)\n\nmovies_df.show(5)\nratings_df.show(5)\n",
