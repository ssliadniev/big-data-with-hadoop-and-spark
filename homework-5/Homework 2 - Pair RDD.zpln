    {
      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\nmovies_exploded_df = movies_df.withColumn(\n    colName=\"genre_name\", \n    col=F.explode(F.split(F.col(\"genres\"), r\"\\|\"))\n).select(\"movieId\", \"genre_name\")\n\nuser_movie_genres_df = ratings_df.join(movies_exploded_df, on=\"movieId\", how=\"inner\")\n\ngenre_preferences_df = user_movie_genres_df.groupBy(\"userId\", \"genre_name\").agg(\n    F.count(\"rating\").alias(\"number_of_ratings\"),\n    F.round(F.avg(\"rating\"), 2).alias(\"average_rating\")\n)\n\nfinal_preferences_df = genre_preferences_df.orderBy(\"userId\", F.col(\"number_of_ratings\").desc())\nfinal_preferences_df.show()",
      "user": "anonymous",
