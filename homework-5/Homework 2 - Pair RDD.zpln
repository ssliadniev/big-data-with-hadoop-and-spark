    {
      "text": "%pyspark\n\nfrom pyspark.sql import functions as F\n\n\navg_ratings_df = ratings_df.groupBy(\"movieId\").agg(\n    F.round(F.avg(\"rating\"), 2).alias(\"avg_rating\")\n)\n\nmovies_with_ratings_df = avg_ratings_df.join(movies_df, on=\"movieId\", how=\"inner\")\n\ntop_10_movies_df = movies_with_ratings_df.orderBy(F.col(\"avg_rating\").desc())\ntop_10_movies_df.select(\"title\", \"avg_rating\").show(10, truncate=False)",
